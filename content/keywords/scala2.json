{
    "type": "keyword_grid",
    "id": "scala2-keyword-grid",
    "groups": [
        {
            "id": "scala2-values",
            "label": "Values",
            "description": "Built-in literal keywords",
            "keywords": ["false", "null", "true"]
        },
        {
            "id": "scala2-declarations",
            "label": "Declarations",
            "description": "Defining types, functions, and values",
            "keywords": [
                { "word": "class", "note": "Defines a reference type with a constructor" },
                { "word": "def", "note": "Defines a method or function" },
                { "word": "lazy", "note": "Delays evaluation of a val until first access" },
                { "word": "object", "note": "Singleton object — combines class and its only instance" },
                { "word": "trait", "note": "Abstract interface that can contain concrete members" },
                { "word": "type", "note": "Declares a type alias or abstract type member" },
                { "word": "val", "note": "Immutable value binding" },
                { "word": "var", "note": "Mutable variable binding" }
            ]
        },
        {
            "id": "scala2-control-flow",
            "label": "Control Flow",
            "description": "Branching, looping, and pattern matching",
            "keywords": [
                "do", "else",
                { "word": "for", "note": "For-comprehension — sequences flatMap/map/filter/foreach" },
                "if",
                { "word": "match", "note": "Pattern-match expression — exhaustive switch on value structure" },
                "return", "while",
                { "word": "yield", "note": "Collects for-comprehension results into a collection" }
            ]
        },
        {
            "id": "scala2-oop",
            "label": "OOP",
            "description": "Object-oriented and trait composition",
            "keywords": [
                { "word": "abstract", "note": "Marks a class or member as requiring a concrete implementation" },
                "case", "class", "extends",
                { "word": "final", "note": "Prevents subclassing or overriding" },
                "new",
                { "word": "object", "note": "Singleton; companion objects share the namespace with a class" },
                { "word": "override", "note": "Required keyword when redefining a member from a superclass" },
                "protected", "private",
                { "word": "sealed", "note": "Restricts subclassing to the same compilation unit" },
                "super", "this", "trait",
                { "word": "with", "note": "Mixes in additional traits" }
            ]
        },
        {
            "id": "scala2-error-handling",
            "label": "Error Handling",
            "description": "Exception management",
            "keywords": ["catch", "finally", "throw", "try"]
        },
        {
            "id": "scala2-modifiers",
            "label": "Modifiers",
            "description": "Declaration modifiers",
            "keywords": [
                { "word": "abstract", "note": "Declares an abstract class or member" },
                { "word": "final", "note": "Prevents subclassing or member override" },
                { "word": "implicit", "note": "Marks a value or function for automatic injection by the compiler" },
                { "word": "lazy", "note": "Defers initialisation until first use" },
                { "word": "override", "note": "Required when shadowing a supertype member" },
                { "word": "sealed", "note": "Limits direct subclasses to the current source file" }
            ]
        },
        {
            "id": "scala2-packages",
            "label": "Packages & Implicits",
            "description": "Module system and implicit resolution",
            "keywords": [
                { "word": "forSome", "note": "Existential type quantifier (mostly obsolete; removed in Scala 3)" },
                "import",
                { "word": "package", "note": "Declares the package this file belongs to" }
            ]
        },
        {
            "id": "scala2-special",
            "label": "Special",
            "description": "Wildcards and pattern identifiers",
            "keywords": [
                { "word": "_", "note": "Wildcard: anonymous variable, import all, placeholder in partial functions" }
            ]
        }
    ]
}
