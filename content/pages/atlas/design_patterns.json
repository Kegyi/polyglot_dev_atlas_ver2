                                    "id": "factory_method",
                                    "title": "Factory Method",
                                    "content": [
                                        {
                                            "type": "text",
                                            "text": "Define an interface for creating objects but let subclasses decide which class to instantiate."
                                        },
                                        {
                                            "type": "text",
                                            "text": "Example implementation across language variants."
                                        },
                                        {
                                            "type": "code",
                                            "path": "design_patterns/factory_method"
                                        }
                                    ]
