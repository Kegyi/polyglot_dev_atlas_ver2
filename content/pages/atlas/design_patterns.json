                                    "title": "Object Pool",
                                    "content": [
                                        {
                                            "type": "text",
                                            "text": "Manage a pool of reusable objects to improve performance and resource utilization."
                                        },
                                        {
                                            "type": "text",
                                            "text": "Example implementation across language variants."
                                        },
                                        {
                                            "type": "code",
                                            "path": "design_patterns/object_pool"
                                        }
                                    ]
