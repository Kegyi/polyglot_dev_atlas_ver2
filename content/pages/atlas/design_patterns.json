                                    "content": [
                                        {
                                            "type": "text",
                                            "text": "Ensure a class has only a limited number of instances and provide a global point of access to them."
                                        },
                                        {
                                            "type": "text",
                                            "text": "Example implementation across language variants."
                                        },
                                        {
                                            "type": "code",
                                            "path": "design_patterns/multiton"
