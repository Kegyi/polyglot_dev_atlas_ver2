                                    "content": [
                                        {
                                            "type": "text",
                                            "text": "Create new objects by copying a prototypical instance, useful for runtime-configurable object creation."
                                        },
                                        {
                                            "type": "text",
                                            "text": "Example implementation across language variants."
                                        },
                                        {
                                            "type": "code",
                                            "path": "design_patterns/prototype"
