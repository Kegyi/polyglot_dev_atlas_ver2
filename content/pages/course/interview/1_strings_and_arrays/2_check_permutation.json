                        },
                        {
                            "type": "text",
                            "text": "\"hello\" and \"oellh\" -> true (permutations of each other)"
                        },
                        {
                            "type": "text",
                            "text": "\"test\" and \"tseta\" -> false (not permutations due to different character counts)"
                        }
