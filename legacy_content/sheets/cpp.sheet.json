        },
        {
          "label": "Macro Definition",
          "items": [
            {"kw": "define", "cat": "preprocessor", "ver": "C++98", "head": "Preprocessor", "desc": "Define a macro or constant", "code": "#define MAX_BUFFER 1024"},
