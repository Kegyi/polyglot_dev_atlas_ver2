{
    "title": {
        "type": "string",
        "description": "Title of the page"
    },
    "description": {
        "type": "string",
        "description": "Description of the page"
    },
    "groups": {
        "type": "object",
        "description": "List of content groups on the page",
        "additionalProperties": {
            "type": "object",
            "properties": {
                "title": { 
                    "type": "string", 
                    "description": "Title of the content group" 
                 },
                "description": { 
                    "type": "string", 
                    "description": "Description of the content group"
                }
            },
            "required": ["title"],
            "additionalProperties": false
        }
    },
    "contents": {
        "type": "object",
        "description": "Collection of content items indexed by unique keys",
        "additionalProperties": {
            "type": "object",
            "description": "Content item",
            "properties": {
                "title": { "type": "string" },
                "label": { "type": "string", "description": "Short label for the content item, used in dropdowns or navigation" },
                "description": { "type": "string" },
                "group": { "type": "string" },
                "insight": {
                    "oneOf": [
                        {
                            "type": "object",
                            "properties": {
                                "text": { "$ref": "#/definitions/optionalInsightText" },
                                "table": { "$ref": "#/definitions/tableStructure" }
                            }
                        },
                        { "$ref": "#/definitions/optionalInsightText" }
                    ]
                },
                "subcontents": {
                    "type": "object",
                    "additionalProperties": {
                        "oneOf": [
                            { "$ref": "#/definitions/codeSnippet" },
                            { "$ref": "#/contents/additionalProperties" } 
                        ]
                    }
                },
                "code": { "$ref": "#/definitions/codeSnippet" }
            },
            "additionalProperties": {
                "oneOf": [
                    { "type": "string" },
                    {
                        "type": "object",
                        "properties": { "text": { "type": "string" } },
                        "required": ["text"],
                        "additionalProperties": false
                    },
                    {
                        "type": "object",
                        "properties": { "table": { "$ref": "#/definitions/tableStructure" } },
                        "required": ["table"],
                        "additionalProperties": false
                    }
                ]
            }
        }
    },
    "definitions": {
        "refPath": {
            "type": "string",
            "description": "Reference path to the content item or code snippet"
        },
        "tableStructure": {
            "type": "object",
            "properties": {
                "headers": { 
                    "type": "array", 
                    "items": { 
                        "type": "string" 
                    } 
                },
                "rows": { 
                    "type": "array", 
                    "items": { 
                        "type": "array", 
                        "items": { 
                            "type": "string" 
                        } 
                    } 
                }
            }
        },
        "optionalInsightText": {
            "type": "string",
            "description": "Insight text (optional)",
            "optional": true
        },
        "codeSnippet": {
            "type": "object",
            "properties": {
                "meta": {
                    "type": "object",
                    "properties": {
                        "title": { "type": "string", "description": "Title of the code snippet" }
                    }
                },
                "languages": {
                    "type": "object",
                    "description": "Code snippets for different programming languages",
                    "additionalProperties": { 
                        "type": "string", 
                        "description": "Code snippet for the specific language" 
                     }
                 }
            },
            "required": ["meta", "languages"]
        }
    }
}